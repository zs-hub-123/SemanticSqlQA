# ============================================================
# SemanticSqlQA - Git忽略文件配置
# 确保敏感信息不会被提交到版本控制
# ============================================================

# ========== 环境变量（包含API密钥和密码） ==========
.env
.env.local
.env.*.local

# ========== Python ==========
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ========== 虚拟环境 ==========
venv/
ENV/
env/
.venv/

# ========== IDE ==========
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ========== 日志文件 ==========
logs/
*.log

# ========== 测试结果（可选提交） ==========
# test_suite/results/*.json

# ========== 数据库备份 ==========
*.sql.bak
*.db
*.sqlite3

# ========== 临时文件 ==========
tmp/
temp/
.cache/

# ========== Node.js (前端) ==========
node_modules/
frontend/dist/
frontend/.vite/

# ========== 敏感配置 ==========
secrets.json
credentials.json
config.local.*

# ========== OS生成文件 ==========
Thumbs.db
Desktop.ini

# ========== Jupyter Notebook ==========
.ipynb_checkpoints/

# ========== 覆盖率报告 ==========
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/
.pytest_cache/
nosetests.xml

# ========== mypy ==========
.mypy_cache/
.dmypy.json
dmypy.json

# ========== Pyre type checker ==========
.pyre/
