# ============================================================
# SemanticSqlQA - 环境变量配置模板
# 四层架构：接入层 → 智能解析层 → MQL中间层 → 语义层 → 数据服务层
# 
# 使用说明：
#   1. 复制此文件为 .env: cp .env.example .env
#   2. 根据你的环境修改下面的配置项
#   3. 确保不要将 .env 文件提交到版本控制
# ============================================================

# ========== 大模型API配置 ==========
# 主模型（必需）
API_KEY=your_api_key_here
API_BASE_URL=https://api.your-llm-provider.com/v1
MODEL_NAME=your-model-name

# 备选模型（可选）
BACKUP_API_KEY=your_backup_api_key_here
BACKUP_API_BASE_URL=http://localhost:port/v1
BACKUP_MODEL_NAME=backup-model-name

# 向量化模型（可选，V5.2已移除Milvus依赖）
EMBEDDING_MODEL=your-embedding-model
EMBEDDING_API=http://localhost:port/api/embedding
API_TIMEOUT=180
MAX_TOKENS=4096
TEMPERATURE=0

# ========== MySQL数据库配置（业务库） ==========
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=text02
DB_CHARSET=utf8mb4

# ========== MySQL语义层库配置 ==========
SEMANTIC_DB_HOST=localhost
SEMANTIC_DB_PORT=3306
SEMANTIC_DB_USER=root
SEMANTIC_DB_PASSWORD=your_semantic_db_password_here
SEMANTIC_DB_NAME=text02_semantic

# ========== Milvus向量库配置（已弃用-V5.2） ==========
# V5.2已移除Milvus依赖，以下配置保留仅用于向后兼容
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=table_schemas_vector

# ========== 服务配置 ==========
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8002

# ========== 日志配置 ==========
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ========== 模型切换配置 ==========
USE_BACKUP_MODEL=false
